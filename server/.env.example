# ========== Генерация реплик ведущего (LLM) ==========
# Провайдер: openai (по умолчанию) или deepseek. DeepSeek рекомендуется для весёлого ведущего с живыми репликами.
# LLM_PROVIDER=deepseek

# --- OpenAI (если LLM_PROVIDER=openai или не задан) ---
# OPENAI_API_KEY=sk-...

# --- DeepSeek (если LLM_PROVIDER=deepseek): реальный ведущий, мат по ситуации, человеческие шутки ---
# DEEPSEEK_API_KEY=sk-...

# ========== TTS (озвучка ведущего) ==========
# Провайдер: openai (по умолчанию) или elevenlabs (лучше для русского).
# TTS_PROVIDER=elevenlabs

# --- OpenAI TTS (если TTS_PROVIDER=openai или не задан) ---
# OPENAI_API_KEY=sk-...  (если уже задан выше для LLM — можно не дублировать)
# Голос: alloy, echo, fable, onyx (по умолчанию), nova, shimmer.
# TTS_VOICE=onyx

# --- ElevenLabs TTS (если TTS_PROVIDER=elevenlabs, лучше русский) ---
# ELEVENLABS_API_KEY=...
# Мужской русский голос: Denis 1EVds7FNGSXoKeOiMXuf, Dmitry kwajW3Xh5svCeKU5ky2S, Ivan 1qd9R09Ljlx9V1Ok0t5S.
# ELEVENLABS_VOICE_ID=1EVds7FNGSXoKeOiMXuf
# Модель: по умолчанию eleven_multilingual_v2 — рекомендуется для русского и естественного звучания.
# TTS_MODEL=eleven_multilingual_v2
# Если ElevenLabs возвращает 403 (Cloudflare) с хостинга (Beget и др.), используйте Cloudflare Worker — см. worker/README.md.
# TTS_CF_WORKER_URL=https://mafia-tts-proxy.<account>.workers.dev
# TTS_CF_WORKER_SECRET=...   # тот же секрет, что в Worker (wrangler secret put TTS_WORKER_SECRET). Ключ тогда хранится только в Worker.
# Если задан TTS_CF_WORKER_URL, ELEVENLABS_API_KEY на сервере не нужен.

# Прокси для TTS (если из-за Cloudflare 403 и не используете Worker): через VPN или локальный прокси.
# Пример: socks5://127.0.0.1:1080  или  http://127.0.0.1:8080
# TTS_PROXY=socks5://127.0.0.1:1080

# ========== Остальное (опционально) ==========
# CORS для Socket.IO и API: по умолчанию * (все домены). В продакшене задайте свой домен.
# CORS_ORIGIN=https://your-domain.com
#
# Пауза ожидания ночи и напоминания:
# MAFIA_NIGHT_WAIT_MS=90000
# MAFIA_NIGHT_NUDGE_MS=20000
#
# Скорость и длительность озвучки ведущего:
# MAFIA_SPEECH_CHARS_PER_SEC=10
# MAFIA_SPEECH_BUFFER_MS=800
# MAFIA_SPEECH_MIN_MS=2200
# MAFIA_SPEECH_MAX_MS=16000
#
# Паузы в сценарии:
# MAFIA_DELAY_AFTER_ROLES_REVEAL_MS=5500           # Время на прочтение карточки роли (после your_role), мс
# MAFIA_DELAY_AFTER_ROLES_DONE_BEFORE_NIGHT_MS=1800 # Пауза после «роли розданы» перед началом ночи, мс
# MAFIA_DELAY_AFTER_WAKE_BEFORE_TURN_MS=1600        # Пауза после «проснитесь» перед показом выбора ночью, мс
# MAFIA_DELAY_AFTER_CHOICE_BEFORE_SLEEP_MS=600      # Пауза после выбора перед «засыпайте», мс
# MAFIA_TRANSITION_PHRASE_MAX_MS=1400
#
# «Последнее слово» исключённого игрока:
# MAFIA_LAST_WORDS_MS=20000
